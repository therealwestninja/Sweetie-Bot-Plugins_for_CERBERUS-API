{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sweetie Execute Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "request_id",
    "plugin",
    "action",
    "version",
    "result",
    "state_patch",
    "events",
    "commands",
    "warnings",
    "errors"
  ],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "request_id": {
      "type": "string"
    },
    "plugin": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "result": {
      "type": "object"
    },
    "state_patch": {
      "type": "object"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "event.schema.json"
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "command.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "error.schema.json"
      }
    }
  }
}
