{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sweetie Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "type",
    "source_plugin",
    "timestamp",
    "session_id",
    "data"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "source_plugin": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "session_id": {
      "type": "string"
    },
    "data": {
      "type": "object"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "visibility": {
      "type": "string",
      "enum": [
        "internal",
        "external",
        "debug"
      ]
    }
  }
}
