{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sweetie Execute Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "timestamp",
    "source",
    "plugin",
    "action",
    "session",
    "context",
    "state",
    "input",
    "policy"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "plugin": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id"
      ],
      "properties": {
        "session_id": {
          "type": "string"
        },
        "conversation_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "actor_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "environment_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "trace_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "user_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "priority": {
          "type": [
            "string",
            "null"
          ]
        },
        "mode": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "state": {
      "type": "object"
    },
    "input": {
      "type": "object"
    },
    "policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dry_run": {
          "type": "boolean"
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "safe_mode": {
          "type": "boolean"
        }
      }
    }
  }
}
