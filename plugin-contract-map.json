    {
      "name": "sweetie-plugin-action-registry",
      "path": "plugins/sweetie-plugin-action-registry",
      "manifest": {
        "name": "sweetie-plugin-action-registry",
        "version": "1.0.0",
        "api_version": 1,
        "display_name": "Sweetie Action Registry Plugin",
        "description": "Named action registration, dispatch, adapter routing, and execution policy layer for CERBERUS-compatible Sweetie plugins.",
        "capabilities": [
          "action.register",
          "action.unregister",
          "action.list",
          "action.get",
          "action.dispatch",
          "action.set_policy",
          "action.status"
        ],
        "entrypoints": {
          "execute": "/execute",
          "docs": "/docs"
        },
        "healthcheck": "/health",
        "port": 7000
      },
      "routes": [
        {
          "method": "POST",
          "path": "/execute",
          "handler": "execute"
        },
        {
          "method": "GET",
          "path": "/health",
          "handler": "health"
        },
        {
          "method": "GET",
          "path": "/manifest",
          "handler": "manifest"
        },
        {
          "method": "GET",
          "path": "/status",
          "handler": "status_route"
        }
      ],
      "execute_actions_seen_in_code": [
        "action.dispatch",
        "action.get",
        "action.list",
        "action.register",
        "action.set_policy",
        "action.status",
        "action.unregister"
      ]
    },
